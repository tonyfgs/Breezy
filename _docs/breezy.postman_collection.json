{
  "info": {
    "name": "Breezy API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000" },
    { "key": "token", "value": "" },
    { "key": "user_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"MonPass1\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  const payload = JSON.parse(atob(json.token.split('.')[1]));",
                  "  pm.collectionVariables.set('user_id', String(payload.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"MonPass1\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Users",
      "item": [
        {
          "name": "Get all users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/users/"
          }
        },
        {
          "name": "Get user by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/users/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "3. Follows",
      "item": [
        {
          "name": "Follow a user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/follows/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"follwerId\": \"{{user_id}}\",\n  \"followingId\": \"<id_de_lautre_user>\"\n}"
            }
          }
        },
        {
          "name": "Get following list",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/follows/{{user_id}}/following"
          }
        },
        {
          "name": "Get followers list",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/follows/{{user_id}}/followers"
          }
        },
        {
          "name": "Unfollow a user",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/follows/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"follwerId\": \"{{user_id}}\",\n  \"followingId\": \"<id_de_lautre_user>\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "4. Posts",
      "item": [
        {
          "name": "Create post",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/posts/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorId\": \"{{user_id}}\",\n  \"content\": \"Mon premier post sur Breezy !\"\n}"
            }
          }
        },
        {
          "name": "Get all posts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/posts/?page=1&limit=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "5. Feed",
      "item": [
        {
          "name": "Get feed",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/feed/{{user_id}}?limit=20",
              "query": [{ "key": "limit", "value": "20" }]
            }
          }
        }
      ]
    }
  ]
}
